{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@supabase/supabase-js": ["../../../node_modules/@supabase/supabase-js"]
    }
  },
  "include": ["./**/*.ts", "./**/*.d.ts"]
}
