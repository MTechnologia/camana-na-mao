# Copie para .env.e2e.local e preencha com um usuário que exista no Supabase do ambiente.
# O arquivo .env.e2e.local não é commitado (.gitignore).
#
# Requisitos:
# - Usuário deve existir em Authentication > Users (mesmo projeto do CAMARA_URL/.env)
# - E-mail deve estar confirmado
# - Se a senha tiver caracteres especiais, use aspas: E2E_TEST_PASSWORD="senha@123"
#
E2E_TEST_EMAIL=seu@email.com
E2E_TEST_PASSWORD=sua_senha
