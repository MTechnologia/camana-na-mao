# Copie para .env e preencha os valores. Não commite o .env (está no .gitignore).
# Em produção (Cloud Run), as variáveis são injetadas pelo Cloud Build (GCP → Trigger → Substitution variables).

# Supabase — preferir prefixo CAMARA_ (VITE_SUPABASE_* continua aceite durante migração)
CAMARA_URL="https://seu-project-id.supabase.co"
CAMARA_PUBLISHABLE_KEY="sua-publishable-key"
CAMARA_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-publishable-key"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# Google Maps (mapa + "Perto de Você"). Restrinja a chave no Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=""

# Web Push (opcional) — chave pública; segredo VAPID fica no Supabase
# VITE_VAPID_PUBLIC_KEY=""
