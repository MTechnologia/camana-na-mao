# Copie para .env e preencha os valores. Não commite o .env.
# Em produção (Cloud Run), as variáveis são injetadas pelo Cloud Build (GCP Console → Trigger → Substitution variables).

# Supabase
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-publishable-key"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# Google Maps (mapa + distâncias a pé no "Perto de Você"). Obrigatório para o mapa em dev; em produção vem do GCP.
# Crie a API key no Google Cloud Console e habilite: Maps JavaScript API, Routes API, Geocoding API.
VITE_GOOGLE_MAPS_API_KEY=""
