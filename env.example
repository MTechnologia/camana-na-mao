# Web (Vite) - padrão do projeto (frontend enxerga só estas)
CAMARA_URL=http://127.0.0.1:54321
CAMARA_PUBLISHABLE_KEY=sb_publishable_xxx
CAMARA_PROJECT_ID=your-project-id

# Scripts locais (ex.: seed-audiencias-from-json.mjs) – NUNCA usar no frontend
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Compat (legado) - opcional durante a migração
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Opcional (para builds públicos do mobile)
# EXPO_PUBLIC_WEB_URL=https://seu-site-no-render.onrender.com/

# Web Push (notificações no navegador) – chave PÚBLICA do VAPID (gerada pelo script em send-web-push/README.md)
# VITE_VAPID_PUBLIC_KEY=BNx...

# Edge Function send-web-push (opcional: URL base do app para links no e-mail)
# APP_URL=https://seusite.com

